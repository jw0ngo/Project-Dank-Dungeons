# Copy this file to `.env` (same folder) and fill in the values.
# .env is gitignored — never commit your real keys.

# ── Telegram (required) ───────────────────────────────────────────────────────
# From @BotFather on Telegram after /newbot
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-here

# Lock the bot to YOUR Telegram chat only. Leave blank on first run — the bot will
# reply with your chat id. Paste it here, then restart.
TELEGRAM_ALLOWED_CHAT_ID=

# ── Which LLM drives the PM agent (provider-agnostic) ─────────────────────────
# anthropic = Claude (default)        openai = any OpenAI-compatible endpoint
LLM_PROVIDER=anthropic

# Optional: override the model and token cap for whichever provider is selected.
# Anthropic default: claude-opus-4-8   OpenAI default: gpt-4o
#LLM_MODEL=
#LLM_MAX_TOKENS=8000

# ── Provider credentials — fill in the ONE matching LLM_PROVIDER ───────────────

# If LLM_PROVIDER=anthropic:
ANTHROPIC_API_KEY=sk-ant-your-key-here

# If LLM_PROVIDER=openai (works for OpenAI, OpenRouter, Groq, Together, Mistral,
# DeepSeek, local Ollama / LM Studio / vLLM — anything speaking /v1/chat/completions).
# Set the base URL for your provider; the default targets OpenAI itself.
#OPENAI_API_KEY=sk-...your-key...
#OPENAI_BASE_URL=https://api.openai.com/v1
# Examples:
#   OpenRouter:  OPENAI_BASE_URL=https://openrouter.ai/api/v1   LLM_MODEL=openai/gpt-4o
#   Groq:        OPENAI_BASE_URL=https://api.groq.com/openai/v1 LLM_MODEL=llama-3.3-70b-versatile
#   Ollama:      OPENAI_BASE_URL=http://localhost:11434/v1      LLM_MODEL=llama3.1  (OPENAI_API_KEY optional)
#
# NOTE: the PM needs a TOOL-CALLING-capable model to update/commit the roadmap.
# Models without function calling can still chat, but can't write ROADMAP.md.
